---
const clients = [
  { name: "Fajar Banua Group", logo: "/clients/fajar-banua-group-logo.png" },
  { name: "Pertamina", logo: "/clients/pertamina-logo.png" },
  { name: "PT. PP (Persero) Tbk", logo: "/clients/PT-PP-Persero-Tbk-logo.jpg" },
  { name: "Tripatra", logo: "/clients/tripatra-logo.png" },
  { name: "Friesland Campina", logo: "/clients/friesland-campina-logo.png" },
];
---

<section class="py-16 bg-white border-y border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <span class="text-slate-400 text-sm font-medium tracking-wider uppercase">Trusted By Industry Leaders</span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5">
      {clients.map(client => (
        <div class="flex items-center justify-center aspect-square bg-slate-50 rounded-xl border border-slate-100 p-6">
          <img
            src={client.logo}
            alt={client.name}
            class="w-full h-full object-contain"
            loading="lazy"
            onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
          />
          <span class="hidden items-center justify-center text-slate-400 font-heading font-bold text-sm text-center leading-tight">{client.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
