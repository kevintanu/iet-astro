---
const reasons = [
  {
    number: "01",
    title: "Multidisciplinary Team",
    description: "Process, mechanical, piping, electrical, instrumentation, civil, and safety engineers — all in-house.",
  },
  {
    number: "02",
    title: "International Code Compliance",
    description: "ASME, API, IEC, NFPA standards with deep familiarity of Indonesian MIGAS and PLN requirements.",
  },
  {
    number: "03",
    title: "Flexible Engagement Models",
    description: "Full EPCM support, engineering-only packages, staff augmentation, or project-based contracts.",
  },
  {
    number: "04",
    title: "Competitive Cost Structure",
    description: "Indonesia-based engineering rates with international-quality deliverables and English documentation.",
  },
];
---

<section id="contact" class="py-24 lg:py-32 bg-slate-50 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20">
      <!-- Left: Why Choose + Contact Info -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-px bg-accent-500"></div>
          <span class="text-accent-500 text-sm font-semibold tracking-wider uppercase">Get Started</span>
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-navy-900 leading-tight mb-6">
          Let's Engineer Your <span class="text-brand-500">Next Project</span>
        </h2>
        <p class="text-slate-500 text-lg leading-relaxed mb-10 max-w-lg">
          Whether you need full FEED/Detail Engineering or specific discipline support, 
          our team is ready to deliver world-class engineering solutions.
        </p>

        <!-- Why choose cards -->
        <div class="space-y-4 mb-12">
          {reasons.map(reason => (
            <div class="flex gap-5 items-start">
              <span class="font-heading text-2xl font-extrabold text-slate-200 leading-none mt-1">{reason.number}</span>
              <div>
                <h4 class="font-heading font-bold text-navy-900 mb-1">{reason.title}</h4>
                <p class="text-slate-500 text-sm leading-relaxed">{reason.description}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Contact details -->
        <div class="space-y-4 p-6 bg-white border border-slate-200 rounded-xl">
          <h4 class="font-heading font-bold text-navy-900">Contact Information</h4>
          <div class="space-y-3">
            <div class="flex items-center gap-3 text-sm">
              <svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-slate-600">Kirana Two Office Tower, Level 10-A, Jl. Boulevard Timur No. 88, Kelapa Gading, Jakarta Utara 14240, Indonesia</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="text-slate-600">sales@indoenergytekniko.com</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <svg class="w-5 h-5 text-brand-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div class="flex flex-col">
                <span class="text-slate-600">+62-812-1332-1917</span>
                <span class="text-slate-600">+62-21-2922-2840</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div>
        <div class="bg-white border border-slate-200 rounded-2xl p-8 lg:p-10 shadow-sm">
          <h3 class="font-heading text-xl font-bold text-navy-900 mb-6">Request a Proposal</h3>
          <form class="space-y-5" id="contact-form">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-navy-900 mb-1.5">Full Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-navy-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-colors duration-200"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-navy-900 mb-1.5">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-navy-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-colors duration-200"
                  placeholder="Company name"
                />
              </div>
            </div>
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-sm font-medium text-navy-900 mb-1.5">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-navy-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-colors duration-200"
                  placeholder="you@company.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-navy-900 mb-1.5">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-navy-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-colors duration-200"
                  placeholder="+62..."
                />
              </div>
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-navy-900 mb-1.5">Service Required</label>
              <select
                id="service"
                name="service"
                required
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-navy-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-colors duration-200 cursor-pointer"
              >
                <option value="">Select a service</option>
                <option value="feed">FEED Engineering</option>
                <option value="detail">Detail Engineering</option>
                <option value="epcm">EPCM Support</option>
                <option value="safety">Safety & Risk Studies</option>
                <option value="3d">3D Plant Modeling</option>
                <option value="project-mgmt">Project Management</option>
                <option value="procurement">Procurement Support</option>
                <option value="construction">Construction Support</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="industry" class="block text-sm font-medium text-navy-900 mb-1.5">Industry</label>
              <select
                id="industry"
                name="industry"
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-navy-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-colors duration-200 cursor-pointer"
              >
                <option value="">Select industry</option>
                <option value="oil-gas">Oil & Gas</option>
                <option value="power">Power Plants</option>
                <option value="petrochem">Petrochemical</option>
                <option value="fertilizer">Fertilizer</option>
                <option value="geothermal">Geothermal</option>
                <option value="renewable">Renewable Energy</option>
                <option value="chemical">Chemical Plants</option>
                <option value="manufacturing">Industrial Manufacturing</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy-900 mb-1.5">Project Description</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-navy-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500/30 focus:border-brand-500 transition-colors duration-200 resize-none"
                placeholder="Brief description of your project requirements, timeline, and scope..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full py-4 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-lg transition-all duration-200 cursor-pointer hover:shadow-lg hover:shadow-accent-500/20 text-base"
            >
              Submit Inquiry
            </button>
            <p class="text-slate-400 text-xs text-center">
              We respond to all engineering inquiries within 24 business hours.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
