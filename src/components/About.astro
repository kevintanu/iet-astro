---
const values = [
  {
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
    title: "Safety First",
    description: "Zero-incident engineering with rigorous HAZOP, SIL, and process safety integration at every design stage.",
  },
  {
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
    title: "Quality Assurance",
    description: "ISO 9001 certified processes with multi-level design review, verification checks, and full documentation traceability.",
  },
  {
    icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
    title: "On-Time Delivery",
    description: "Disciplined project controls and milestone tracking to ensure engineering deliverables meet your project schedule.",
  },
  {
    icon: "M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9",
    title: "International Standards",
    description: "All designs comply with ASME, API, IEC, NFPA, and local Indonesian regulations — ready for global review.",
  },
];
---

<section id="about" class="py-24 lg:py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20">
      <!-- Left: About Content -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-px bg-accent-500"></div>
          <span class="text-accent-500 text-sm font-semibold tracking-wider uppercase">About IET</span>
        </div>
        <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-navy-900 leading-tight mb-6">
          Your Trusted Partner in <span class="text-brand-500">Plant Engineering</span>
        </h2>
        <div class="space-y-4 text-slate-500 text-base leading-relaxed">
          <p>
            PT. Indo Energy Tekniko (IET) is a leading industrial engineering consultant 
            and EPCM support company headquartered in Jakarta, Indonesia. We specialize in 
            providing comprehensive engineering design solutions for the energy, oil & gas, 
            petrochemical, and process industries.
          </p>
          <p>
            Our multidisciplinary team of experienced engineers delivers end-to-end services 
            from FEED through detail engineering, procurement support, and construction 
            supervision — enabling our clients to execute capital projects with confidence, 
            on schedule, and within budget.
          </p>
        </div>

        <!-- Values Grid -->
        <div class="grid sm:grid-cols-2 gap-6 mt-10">
          {values.map(value => (
            <div class="flex gap-4">
              <div class="shrink-0 w-10 h-10 bg-brand-500/10 rounded-lg flex items-center justify-center mt-0.5">
                <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={value.icon} />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-navy-900 mb-1">{value.title}</h3>
                <p class="text-slate-500 text-sm leading-relaxed">{value.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Certifications & Standards -->
      <div>
        <!-- Certifications & Standards -->
        <div class="bg-white border border-slate-200 rounded-2xl p-8">
          <h3 class="font-heading text-lg font-bold text-navy-900 mb-6">Standards & Codes We Work With</h3>
          <div class="grid grid-cols-2 gap-4">
            {[
              { code: "API", label: "Petroleum Industry" },
              { code: "ASME", label: "Mechanical Engineering" },
              { code: "ASTM", label: "Materials & Testing" },
              { code: "DNV", label: "Risk Management" },
              { code: "IEEE", label: "Electrical Standards" },
              { code: "JIS", label: "Japanese Industrial" },
              { code: "BSI", label: "British Standards" },
              { code: "ANSI", label: "National Standards" },
              { code: "Lloyd's Register", label: "Classification" },
            ].map(cert => (
              <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-lg">
                <div class="w-8 h-8 bg-brand-500/10 rounded flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-brand-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <div class="font-heading font-bold text-navy-900 text-sm">{cert.code}</div>
                  <div class="text-slate-500 text-xs">{cert.label}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
