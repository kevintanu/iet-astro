  {
    icon: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z",
    name: "Oil & Gas",
    description: "Upstream, midstream, and downstream facility engineering including refineries, gas processing, and pipeline systems.",
    projects: "80+",
  },
  {
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    name: "Power Plants",
    description: "Thermal, gas turbine, combined cycle, and cogeneration plant design from feasibility through commissioning support.",
    projects: "35+",
  },
  {
    icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
    name: "Petrochemical",
    description: "Ethylene, polyethylene, aromatics, and specialty chemical plant engineering with advanced process integration.",
    projects: "25+",
  },
  {
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    name: "Geothermal",
    description: "Geothermal power plant engineering including wellhead equipment, steam gathering, and binary cycle systems.",
    projects: "12+",
  },
  {
    icon: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4",
    name: "Pharmaceutical",
    description: "GMP-compliant pharmaceutical manufacturing facilities, clean room design, and process validation engineering.",
    projects: "10+",
  },
  {
    icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    name: "FMCG & Manufacturing",
    description: "Fast-moving consumer goods production lines, packaging facilities, and industrial manufacturing plant engineering.",
    projects: "10+",
  },
  {
    icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z",
    name: "Renewable Energy",
    description: "Solar, wind, biomass, and waste-to-energy engineering solutions supporting Indonesia's energy transition goals.",
    projects: "10+",
  },
