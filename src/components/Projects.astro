---
const projects = [
  {
    category: "Oil & Gas",
    title: "Crude Oil Refinery Expansion",
    image: "/projects/project-1.jpg",
    description: "",
  },
  {
    category: "Power Plant",
    title: "Combined Cycle Power Plant",
    image: "/projects/project-2.jpg",
    description: "",
  },
  {
    category: "Petrochemical",
    title: "Olefins Plant Revamp",
    image: "/projects/project-3.jpg",
    description: "",
  },
  {
    category: "Geothermal",
    title: "Geothermal Power Station",
    image: "/projects/project-4.jpg",
    description: "",
  },
];
---

<section id="projects" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-3xl mb-16 lg:mb-20">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-px bg-accent-500"></div>
        <span class="text-accent-500 text-sm font-semibold tracking-wider uppercase">Project Experience</span>
      </div>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-navy-900 leading-tight">
        Proven Track Record in <span class="text-brand-500">Complex Projects</span>
      </h2>
      <p class="mt-5 text-slate-500 text-lg leading-relaxed">
        Selected references from our portfolio of successfully delivered engineering projects.
      </p>
    </div>

    <!-- Project Cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {projects.map((project) => (
        <div class="group border border-slate-200 hover:border-brand-500/30 rounded-xl overflow-hidden transition-all duration-300 hover:shadow-lg hover:shadow-brand-500/5">
          <!-- Image -->
          <div class="aspect-[4/3] bg-slate-100 overflow-hidden relative">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="hidden absolute inset-0 items-center justify-center bg-slate-100">
              <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
          </div>
          <!-- Content -->
          <div class="p-5">
            <span class="text-accent-500 text-xs font-bold tracking-wider uppercase">{project.category}</span>
            <h3 class="font-heading text-base font-bold text-navy-900 mt-1.5">{project.title}</h3>
            {project.description && (
              <p class="text-slate-500 text-sm mt-2 leading-relaxed">{project.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA row -->
    <div class="mt-12 text-center">
      <p class="text-slate-500 mb-4">Interested in our full project portfolio and reference list?</p>
      <a href="#contact" class="inline-flex items-center gap-2 text-brand-500 hover:text-brand-600 font-semibold transition-colors duration-200 cursor-pointer">
        Request our credentials package
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</section>
