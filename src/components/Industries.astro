---

<section id="industries" class="py-24 lg:py-32 bg-navy-950 relative overflow-hidden">
  <!-- Background elements -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 80px 80px;"></div>
  <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-brand-600/5 rounded-full blur-[120px]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-20">
      <div class="inline-flex items-center gap-3 mb-4">
        <div class="w-10 h-px bg-accent-500"></div>
        <span class="text-accent-500 text-sm font-semibold tracking-wider uppercase">Industries We Serve</span>
        <div class="w-10 h-px bg-accent-500"></div>
      </div>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
        Engineering Expertise Across <span class="text-brand-400">Critical Industries</span>
      </h2>
      <p class="mt-5 text-slate-400 text-lg leading-relaxed">
        Deep domain knowledge and proven track record across the most demanding 
        sectors of the energy and process industries.
      </p>
    </div>

    <!-- Industries Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {industries.map(industry => (
        <div class="group bg-white/[0.03] hover:bg-white/[0.06] border border-white/[0.06] hover:border-accent-500/30 rounded-xl p-7 transition-all duration-300 cursor-pointer relative overflow-hidden">
          <!-- Accent top border on hover -->
          <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-accent-500 to-brand-400 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>

          <div class="flex items-start gap-5">
            <div class="shrink-0 w-12 h-12 bg-brand-500/10 group-hover:bg-accent-500/15 rounded-lg flex items-center justify-center transition-colors duration-300">
              <svg class="w-6 h-6 text-brand-400 group-hover:text-accent-400 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={industry.icon} />
              </svg>
            </div>
            <div class="flex-1">
              <div class="mb-2">
                <h3 class="font-heading text-lg font-bold text-white">{industry.name}</h3>
              </div>
              <p class="text-slate-400 text-sm leading-relaxed">{industry.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Geography bar -->
    <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-8 text-center">
      <div class="text-slate-500 text-sm font-medium uppercase tracking-wider">Active Regions</div>
      <div class="flex flex-wrap justify-center gap-6">
        {["Indonesia", "India", "UAE", "Australia"].map(region => (
          <div class="flex items-center gap-2 text-slate-300 text-sm">
            <div class="w-2 h-2 bg-accent-500 rounded-full"></div>
            {region}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
