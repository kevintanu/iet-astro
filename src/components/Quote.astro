---

<section class="py-24 lg:py-32 bg-slate-50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Photo -->
      <div class="lg:col-span-4">
        <div class="aspect-square max-w-xs mx-auto lg:max-w-none overflow-hidden rounded-2xl border border-slate-200 shadow-lg">
          <img
            src="/team/aarti-sandhal.jpg"
            alt="Aarti Sandhal - Director, PT. Indo Energy Tekniko"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <!-- Quote -->
      <div class="lg:col-span-8">
        <svg class="w-12 h-12 text-brand-500/20 mb-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983z" />
        </svg>
        <blockquote class="font-heading text-2xl sm:text-3xl lg:text-4xl font-extrabold text-navy-900 leading-snug mb-8">
          We don't just deliver drawings — we deliver engineered solutions that are 
          <span class="text-brand-500">buildable, safe, and cost-effective</span> from day one.
        </blockquote>
        <div class="flex items-center gap-4">
          <div class="w-12 h-px bg-accent-500"></div>
          <div>
            <div class="font-heading font-bold text-navy-900">Aarti Sandhal</div>
            <div class="text-slate-500 text-sm">Director, PT. Indo Energy Tekniko</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
