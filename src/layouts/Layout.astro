---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "PT. Indo Energy Tekniko | Industrial Engineering & EPCM Solutions",
	description = "Leading industrial engineering consultant providing FEED, Detail Engineering, EPCM support, and plant design solutions for Oil & Gas, Power Plants, Petrochemical, and Process Industries across Indonesia and Southeast Asia."
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="theme-color" content="#0B1426" />
	</head>
	<body class="min-h-screen">
		<slot />
	</body>
</html>
