---
const services = [
  {
    icon: "process",
    title: "FEED Engineering",
    description: "Front-End Engineering Design covering process flow development, equipment sizing, P&ID development, and project cost estimation to support investment decisions.",
    tags: ["Process Design", "P&ID", "Cost Estimation"],
  },
  {
    icon: "detail",
    title: "Industrial Plant Design",
    description: "Complete engineering design packages including facility layout, fabrication drawings, bill of quantities, piping spools, and vessel design per ASME Section VIII and API codes.",
    tags: ["Plant Layout", "Fabrication Drawings", "BOQ"],
  },
  {
    icon: "piping",
    title: "Piping Engineering",
    description: "Piping layout, routing, isometric drawings, material take-off, spool drawings, and stress analysis using ANSI, ASME, and European standards for new and existing systems.",
    tags: ["Stress Analysis", "Piping Spools", "MTO"],
  },
  {
    icon: "electrical",
    title: "Electrical & Instrumentation",
    description: "Power distribution, single line diagrams, electrical panel design, cable sizing, wiring diagrams, instrument specification, and control system architecture.",
    tags: ["Panel & Wiring", "DCS/PLC", "BOM"],
  },
  {
    icon: "structural",
    title: "Structural Analysis & Design",
    description: "Structural analysis and simulation to determine load effects on physical structures — including support columns, beams, platforms, and pipe racks — verifying fitness for use without physical testing.",
    tags: ["FEA Simulation", "Steel Structure", "Load Analysis"],
  },
  {
    icon: "fire",
    title: "Fire Protection Engineering",
    description: "Design of fire fighting systems, fire protection systems, fire and gas detection layout, and active/passive fire protection solutions for industrial facilities.",
    tags: ["Fire Fighting", "F&G Detection", "Passive Protection"],
  },
  {
    icon: "safety",
    title: "Safety & Risk Studies",
    description: "Comprehensive safety consulting including HAZID, HAZOP, SIL classification and verification, FERA (Fire & Explosion Risk Analysis), and QRA (Quantitative Risk Assessment) studies.",
    tags: ["HAZID/HAZOP", "FERA/QRA", "SIL Verification"],
  },
  {
    icon: "modeling",
    title: "3D Plant Modeling",
    description: "Full 3D plant models for clash detection, constructability review, and virtual walk-through using industry-standard platforms.",
    tags: ["PDMS/E3D", "Clash Detection", "Review"],
  },
];

const iconPaths: Record<string, string> = {
  process: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  detail: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  piping: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
  electrical: "M13 10V3L4 14h7v7l9-11h-7z",
  structural: "M4 6h16M4 10h16M4 14h16M4 18h16",
  fire: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z",
  safety: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  modeling: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
};
---

<section id="services" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 lg:mb-20">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-px bg-accent-500"></div>
        <span class="text-accent-500 text-sm font-semibold tracking-wider uppercase">Our Capabilities</span>
      </div>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold text-navy-900 leading-tight">
        Comprehensive Engineering <br class="hidden sm:block"/>
        <span class="text-brand-500">Design Solutions</span>
      </h2>
      <p class="mt-5 text-slate-500 text-lg leading-relaxed max-w-2xl">
        End-to-end engineering services from conceptual design through detail engineering, 
        project management, and construction support — all under one roof.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {services.map((service, i) => (
        <div class="group relative bg-slate-50 hover:bg-navy-900 border border-slate-200 hover:border-navy-800 rounded-xl p-6 transition-all duration-300 cursor-pointer">
          <!-- Icon -->
          <div class="w-12 h-12 bg-brand-500/10 group-hover:bg-accent-500/20 rounded-lg flex items-center justify-center mb-5 transition-colors duration-300">
            <svg class="w-6 h-6 text-brand-500 group-hover:text-accent-400 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon]} />
            </svg>
          </div>

          <!-- Content -->
          <h3 class="font-heading text-lg font-bold text-navy-900 group-hover:text-white mb-2 transition-colors duration-300">
            {service.title}
          </h3>
          <p class="text-slate-500 group-hover:text-slate-400 text-sm leading-relaxed mb-4 transition-colors duration-300">
            {service.description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-1.5">
            {service.tags.map(tag => (
              <span class="text-[11px] px-2 py-0.5 bg-slate-200/60 group-hover:bg-white/10 text-slate-500 group-hover:text-slate-400 rounded transition-colors duration-300">
                {tag}
              </span>
            ))}
          </div>

          <!-- Hover indicator line -->
          <div class="absolute bottom-0 left-6 right-6 h-0.5 bg-accent-500 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left rounded-full"></div>
        </div>
      ))}
    </div>

    <!-- Additional services row -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-slate-500">
      <span class="font-medium text-navy-900">Also specializing in:</span>
      {["Renewable Energy & Feasibility Studies", "Vessel & Tank Design", "Heat Exchangers & Boilers", "Project Management", "Procurement Support", "Construction Support"].map(item => (
        <span class="flex items-center gap-2">
          <span class="w-1 h-1 bg-accent-500 rounded-full"></span>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
